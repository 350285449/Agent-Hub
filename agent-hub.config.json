{
  "host": "127.0.0.1",
  "port": 8787,
  "state_dir": ".agent-hub/state",
  "inbox_dir": ".agent-hub/inbox",
  "outbox_dir": ".agent-hub/outbox",
  "archive_dir": ".agent-hub/archive",
  "workspace_dir": ".",
  "agent_max_steps": 8,
  "allow_shell_tools": false,
  "free_only": true,
  "include_raw_responses": false,
  "expose_routing_details": true,
  "default_route": [
    "claude",
    "gemini",
    "chatgpt",
    "ollama-local",
    "echo"
  ],
  "routes": [
    {
      "name": "coding",
      "keywords": [
        "code",
        "bug",
        "fix",
        "refactor",
        "test",
        "repo"
      ],
      "agents": [
        "claude",
        "gemini",
        "chatgpt",
        "ollama-local",
        "echo"
      ]
    },
    {
      "name": "local-agent",
      "keywords": [
        "agent",
        "workspace",
        "edit",
        "implement"
      ],
      "agents": [
        "ollama-local"
      ]
    },
    {
      "name": "hybrid-agent",
      "keywords": [],
      "agents": [
        "claude",
        "gemini",
        "chatgpt",
        "ollama-local",
        "echo"
      ]
    },
    {
      "name": "cloud-agent",
      "keywords": [],
      "agents": [
        "claude",
        "gemini",
        "chatgpt",
        "ollama-local",
        "echo"
      ]
    },
    {
      "name": "research",
      "keywords": [
        "research",
        "search",
        "latest",
        "sources",
        "web",
        "news"
      ],
      "agents": [
        "local-research",
        "claude",
        "gemini",
        "chatgpt",
        "echo"
      ]
    }
  ],
  "agents": [
    {
      "name": "local-research",
      "provider": "local-research",
      "model": "local-extractive-research",
      "free": true,
      "context_window": 1000000,
      "timeout_seconds": 20,
      "cooldown_seconds": 5
    },
    {
      "name": "claude",
      "provider": "openai-compatible",
      "model": "qwen2.5-coder:7b",
      "base_url": "http://127.0.0.1:11434",
      "enabled": true,
      "free": true,
      "max_tokens": 4096,
      "context_window": 32768,
      "timeout_seconds": 120,
      "cooldown_seconds": 30
    },
    {
      "name": "gemini",
      "provider": "openai-compatible",
      "model": "qwen2.5-coder:7b",
      "base_url": "http://127.0.0.1:11434",
      "enabled": true,
      "free": true,
      "max_tokens": 4096,
      "context_window": 128000,
      "timeout_seconds": 120,
      "cooldown_seconds": 30
    },
    {
      "name": "chatgpt",
      "provider": "openai-compatible",
      "model": "qwen2.5-coder:7b",
      "base_url": "http://127.0.0.1:11434",
      "enabled": true,
      "free": true,
      "max_tokens": 4096,
      "context_window": 128000,
      "timeout_seconds": 120,
      "cooldown_seconds": 30
    },
    {
      "name": "ollama-local",
      "provider": "openai-compatible",
      "model": "qwen2.5-coder:7b",
      "base_url": "http://127.0.0.1:11434",
      "free": true,
      "max_tokens": 4096,
      "context_window": 32768,
      "timeout_seconds": 300,
      "cooldown_seconds": 10
    },
    {
      "name": "echo",
      "provider": "echo",
      "model": "local-echo",
      "free": true,
      "context_window": 1000000,
      "cooldown_seconds": 1
    }
  ]
}
