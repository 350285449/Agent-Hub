{
  "host": "127.0.0.1",
  "port": 8787,
  "state_dir": ".agent-hub/state",
  "inbox_dir": ".agent-hub/inbox",
  "outbox_dir": ".agent-hub/outbox",
  "archive_dir": ".agent-hub/archive",
  "workspace_dir": ".",
  "agent_max_steps": 8,
  "allow_shell_tools": true,
  "free_only": true,
  "include_raw_responses": false,
  "expose_routing_details": false,
  "default_route": ["codex", "claude", "gemini", "chatgpt", "ollama-qwen-coder", "ollama-qwen3", "lm-studio", "vllm", "custom-local", "localai", "echo"],
  "routes": [
    {
      "name": "coding",
      "keywords": ["code", "bug", "fix", "refactor", "test", "repo"],
      "agents": ["codex", "claude", "gemini", "chatgpt", "ollama-qwen-coder", "ollama-qwen3", "lm-studio", "vllm", "custom-local", "localai", "echo"]
    },
    {
      "name": "local-agent",
      "keywords": ["agent", "workspace", "edit", "implement"],
      "agents": ["ollama-qwen-coder", "ollama-qwen3", "lm-studio", "vllm", "custom-local", "localai"]
    },
    {
      "name": "hybrid-agent",
      "keywords": [],
      "agents": ["codex", "claude", "gemini", "chatgpt", "ollama-qwen-coder", "ollama-qwen3", "lm-studio", "vllm", "custom-local", "localai", "echo"]
    },
    {
      "name": "cloud-agent",
      "keywords": [],
      "agents": ["codex", "claude", "gemini", "chatgpt", "ollama-qwen-coder", "ollama-qwen3", "lm-studio", "vllm", "custom-local", "localai", "echo"]
    },
    {
      "name": "research",
      "keywords": ["research", "search", "latest", "sources", "web", "news"],
      "agents": ["local-research", "codex", "claude", "gemini", "chatgpt", "echo"]
    }
  ],
  "agents": [
    {
      "name": "local-research",
      "provider": "local-research",
      "model": "local-extractive-research",
      "free": true,
      "context_window": 1000000,
      "timeout_seconds": 20,
      "cooldown_seconds": 5
    },
    {
      "name": "codex",
      "provider": "openai-compatible",
      "model": "local-model",
      "base_url": "http://127.0.0.1:1234",
      "enabled": true,
      "free": true,
      "max_tokens": 4096,
      "context_window": 32768,
      "timeout_seconds": 120,
      "cooldown_seconds": 30
    },
    {
