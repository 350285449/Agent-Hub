{
  "host": "127.0.0.1",
  "port": 8787,
  "state_dir": ".agent-hub/state",
  "inbox_dir": ".agent-hub/inbox",
  "outbox_dir": ".agent-hub/outbox",
  "archive_dir": ".agent-hub/archive",
  "workspace_dir": ".",
  "agent_max_steps": 8,
  "allow_shell_tools": false,
  "free_only": true,
  "include_raw_responses": false,
  "default_route": ["custom-local", "echo"],
  "routes": [
    {
      "name": "coding",
      "keywords": ["code", "bug", "fix", "refactor", "test", "repo"],
      "agents": ["custom-local", "echo"]
    }
  ],
  "agents": [
    {
      "name": "custom-local",
      "provider": "openai-compatible",
      "model": "local-model",
      "base_url": "http://127.0.0.1:8000",
      "free": true,
      "max_tokens": 4096,
      "context_window": 8192,
      "timeout_seconds": 120,
      "cooldown_seconds": 20
    },
    {
      "name": "echo",
      "provider": "echo",
      "model": "local-echo",
      "free": true,
      "context_window": 1000000,
      "cooldown_seconds": 1
    },
    {
      "name": "gemma-local",
      "provider": "gemma",
      "model": "your-gemma-model",
      "base_url": "http://127.0.0.1:8000",
      "enabled": false,
      "free": true,
      "max_tokens": 4096,
      "context_window": 8192
    },
    {
      "name": "chatgpt",
      "provider": "chatgpt",
      "model": "your-openai-model",
      "api_key_env": "OPENAI_API_KEY",
      "enabled": false,
      "free": false,
      "max_tokens": 4096,
      "context_window": 128000
    },
    {
      "name": "gemini",
      "provider": "gemini",
      "model": "your-gemini-model",
      "api_key_env": "GEMINI_API_KEY",
      "enabled": false,
      "free": false,
      "max_tokens": 4096,
      "context_window": 1000000
    },
    {
      "name": "claude",
      "provider": "claude",
      "model": "your-claude-model",
      "api_key_env": "ANTHROPIC_API_KEY",
      "enabled": false,
      "free": false,
      "max_tokens": 4096,
      "context_window": 200000
    }
  ]
}
