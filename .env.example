# Agent Hub provider keys. Keep real values out of git.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# Optional runtime defaults for container deployments.
AGENT_HUB_HOST=0.0.0.0
AGENT_HUB_PORT=8787
AGENT_HUB_API_TOKEN=replace-with-a-long-random-token
AGENT_HUB_TRUSTED_APPROVAL_TOKEN=replace-with-a-separate-long-random-token

# Optional routing-memory controls.
ROUTING_MEMORY_ENABLED=true
ROUTING_MEMORY_STORE_PROMPTS=false
ROUTING_MEMORY_RETENTION_DAYS=30
