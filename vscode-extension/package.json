{
  "name": "agent-hub-vscode",
  "displayName": "Agent Hub Workspace",
  "description": "Run permissioned VS Code workspace agents through Ollama Cloud, hosted providers, or local models.",
  "version": "0.7.17",
  "publisher": "agent-hub",
  "license": "MIT",
  "icon": "assets/agent-hub-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/350285449/Agent-Hub.git"
  },
  "bugs": {
    "url": "https://github.com/350285449/Agent-Hub/issues"
  },
  "homepage": "https://github.com/350285449/Agent-Hub#readme",
  "keywords": [
    "ai",
    "agent",
    "local-ai",
    "ollama",
    "coding-agent",
    "cline",
    "claude-code",
    "openai-compatible",
    "anthropic",
    "llm-router"
  ],
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onView:agentHub.sidebar",
    "onChatParticipant:agent-hub.agent-hub-vscode.agenthub",
    "onCommand:agentHub.chat",
    "onCommand:agentHub.startServer",
    "onCommand:agentHub.stopServer",
    "onCommand:agentHub.restartServer",
    "onCommand:agentHub.checkHealth",
    "onCommand:agentHub.openSettings",
    "onCommand:agentHub.status",
    "onCommand:agentHub.ask",
    "onCommand:agentHub.codeAgent",
    "onCommand:agentHub.research",
    "onCommand:agentHub.explainSelection",
    "onCommand:agentHub.explainFile",
    "onCommand:agentHub.copyClineConfig",
    "onCommand:agentHub.testClineConnection",
    "onCommand:agentHub.showClineSetup",
    "onCommand:agentHub.copyClaudeCodeConfig",
    "onCommand:agentHub.testAnthropicEndpoint",
    "onCommand:agentHub.showClaudeCodeSetup",
    "onCommand:agentHub.openOutput"
  ],
  "main": "./extension.js",
  "scripts": {
    "check": "node --check extension.js",
    "check:version": "node scripts/check-version.js",
    "check:vsix": "python ../scripts/validate_vsix_cleanliness.py",
    "generate-backend-snapshot": "python ../scripts/generate_backend_snapshot.py",
    "validate-backend-drift": "python ../scripts/validate_backend_drift.py",
    "validate-release": "python ../scripts/validate_release.py",
    "update-release-metadata": "python ../scripts/update_release_metadata.py",
    "package-clean": "python ../scripts/package_clean.py",
    "release-summary": "python ../scripts/release_summary.py",
    "compile": "npm run check",
    "test": "npm run check",
    "install-extension": "node scripts/install-extension.js",
    "mount": "node scripts/install-extension.js",
    "prepare-backend": "node scripts/prepare-backend.js",
    "package": "npm run prepare-backend && npm run validate-backend-drift && npx @vscode/vsce package --allow-missing-repository && npm run check:vsix",
    "publish": "npm run prepare-backend && npm run validate-release && npx @vscode/vsce publish --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "agent-hub.agent-hub-vscode.agenthub",
        "name": "agenthub",
        "fullName": "Agent Hub",
        "description": "Run cloud or local workspace agents",
        "isSticky": true,
        "commands": [
          {
            "name": "agent",
            "description": "Inspect or change the current workspace"
          },
          {
            "name": "explain",
            "description": "Explain the current selection or file"
          },
          {
            "name": "research",
            "description": "Research the web with local synthesis"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "agentHub.chat",
        "title": "Agent Hub: Open Chat"
      },
      {
        "command": "agentHub.startServer",
        "title": "Agent Hub: Start Server"
      },
      {
        "command": "agentHub.stopServer",
        "title": "Agent Hub: Stop Server"
      },
      {
        "command": "agentHub.restartServer",
        "title": "Agent Hub: Restart Server"
      },
      {
        "command": "agentHub.checkHealth",
        "title": "Agent Hub: Check Health"
      },
      {
        "command": "agentHub.openSettings",
        "title": "Agent Hub: Open Settings"
      },
      {
        "command": "agentHub.status",
        "title": "Agent Hub: Show Status"
      },
      {
        "command": "agentHub.ask",
        "title": "Agent Hub: Ask Agent"
      },
      {
        "command": "agentHub.codeAgent",
        "title": "Agent Hub: Run Coding Agent"
      },
      {
        "command": "agentHub.research",
        "title": "Agent Hub: Research Web"
      },
      {
        "command": "agentHub.explainSelection",
        "title": "Agent Hub: Explain Selection"
      },
      {
        "command": "agentHub.explainFile",
        "title": "Agent Hub: Explain Current File"
      },
      {
        "command": "agentHub.copyClineConfig",
        "title": "Agent Hub: Copy Cline Config"
      },
      {
        "command": "agentHub.testClineConnection",
        "title": "Agent Hub: Test Cline Connection"
      },
      {
        "command": "agentHub.showClineSetup",
        "title": "Agent Hub: Show Cline Setup"
      },
      {
        "command": "agentHub.copyClaudeCodeConfig",
        "title": "Agent Hub: Copy Claude Code Config"
      },
      {
        "command": "agentHub.testAnthropicEndpoint",
        "title": "Agent Hub: Test Anthropic Endpoint"
      },
      {
        "command": "agentHub.showClaudeCodeSetup",
        "title": "Agent Hub: Show Claude Code Setup"
      },
      {
        "command": "agentHub.openOutput",
        "title": "Agent Hub: Open Output"
      }
    ],
    "configuration": {
      "title": "Agent Hub",
      "properties": {
        "agentHub.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8787",
          "description": "Agent-Hub server URL."
        },
        "agentHub.pythonPath": {
          "type": "string",
          "default": "auto",
          "description": "Python executable used to start Agent-Hub. Use auto to try workspace .venv, Python Launcher, python, and python3 until a Python 3.11+ runtime is found."
        },
        "agentHub.configPath": {
          "type": "string",
          "default": "agent-hub.config.json",
          "description": "Path to Agent-Hub config, relative to the workspace root unless absolute."
        },
        "agentHub.route": {
          "type": "string",
          "default": "coding",
          "description": "Default Agent-Hub route used by VS Code commands."
        },
        "agentHub.researchRoute": {
          "type": "string",
          "default": "research",
          "description": "Agent-Hub route used by the Research Web command."
        },
        "agentHub.codingAgentRoute": {
          "type": "string",
          "default": "local-agent",
          "description": "Agent-Hub route used when provider mode is local."
        },
        "agentHub.agentProviderMode": {
          "type": "string",
          "enum": [
            "local",
            "hybrid",
            "cloud"
          ],
          "default": "cloud",
          "description": "Control agent provider mode. Cloud uses the configured cloud-agent route, hybrid tries that route then local fallbacks, and local uses direct LM Studio/Ollama routes."
        },
        "agentHub.agentMaxSteps": {
          "type": "number",
          "default": 20,
          "description": "Maximum tool steps for agent requests."
        },
        "agentHub.agentContextBudgetTokens": {
          "type": "number",
          "default": 32000,
          "minimum": 1000,
          "description": "Input-token budget for compacting long Agent Hub workspace-agent histories."
        },
        "agentHub.agentContextCompactionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Compact old Agent Hub tool results before model calls to reduce context growth."
        },
        "agentHub.agentMode": {
          "type": "string",
          "enum": [
            "agent",
            "group-agent"
          ],
          "default": "agent",
          "description": "Workspace agent mode. Standard agent uses one routed model loop; group-agent coordinates planner, researcher, coder, reviewer, fixer, and finalizer roles."
        },
        "agentHub.approvalMode": {
          "type": "string",
          "enum": [
            "ask",
            "auto",
            "safe",
            "readonly",
            "shell-ask",
            "deny"
          ],
          "default": "ask",
          "description": "Permission mode for privileged Agent Hub actions. Ask prompts before commands, file/config changes, process control, model downloads, and cloud provider use."
        },
        "agentHub.contextMode": {
          "type": "string",
          "enum": [
            "minimal",
            "balanced",
            "deep"
          ],
          "default": "balanced",
          "description": "Adaptive context mode for Agent Hub token budgeting."
        },
        "agentHub.clineCompatibilityMode": {
          "type": "boolean",
          "default": true,
          "description": "Preserve Cline/Claude Code structured content, task_progress, TODO state, tool chains, and active editor metadata during normalization and compaction."
        },
        "agentHub.groupPlanCandidates": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 5,
          "description": "Number of planner candidates to ask in group-agent mode."
        },
        "agentHub.allowShellTools": {
          "type": "boolean",
          "default": true,
          "description": "Allow the coding agent command to run shell commands in the workspace."
        },
        "agentHub.maxTokens": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "Optional maximum output tokens for VS Code agent requests. Null lets Agent Hub choose automatically."
        },
        "agentHub.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the local Agent-Hub server automatically when sending a request and the server is offline."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentHub",
          "title": "Agent Hub",
          "icon": "assets/activitybar.svg"
        }
      ]
    },
    "views": {
      "agentHub": [
        {
          "id": "agentHub.sidebar",
          "name": "Agent Hub",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "agentHub.startServer",
          "when": "view == agentHub.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "agentHub.checkHealth",
          "when": "view == agentHub.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "agentHub.openSettings",
          "when": "view == agentHub.sidebar",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "agentHub.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation@9"
        },
        {
          "command": "agentHub.explainFile",
          "group": "navigation@10"
        }
      ]
    }
  }
}
