{
  "host": "0.0.0.0",
  "port": 8787,
  "state_dir": "/data/.agent-hub/state",
  "inbox_dir": "/data/.agent-hub/inbox",
  "outbox_dir": "/data/.agent-hub/outbox",
  "archive_dir": "/data/.agent-hub/archive",
  "workspace_dir": "/workspace",
  "approval_mode": "auto",
  "cline_compatibility_mode": true,
  "force_compatibility_streaming": true,
  "free_only": false,
  "enable_load_balancing": true,
  "context_cache_enabled": true,
  "context_cache_max_entries": 256,
  "plugins_enabled": true,
  "plugin_dirs": ["/workspace/.agent-hub/plugins"],
  "repo_ignore_patterns": [
    ".agent-hub/**",
    "state/**",
    "sessions/**",
    "logs/**",
    "*.log",
    "__pycache__/**",
    ".pytest_cache/**"
  ],
  "compatibility_mode": {
    "minimal_tool_schema": true,
    "reduced_repo_context": true,
    "max_context_tokens": 12000
  },
  "default_route": ["local-ollama", "cloud-openai"],
  "routes": [
    {"name": "coding", "keywords": ["code", "debug", "test"], "agents": ["local-ollama", "cloud-openai"]},
    {"name": "cloud-agent", "keywords": [], "agents": ["local-ollama", "cloud-openai"]}
  ],
  "agents": [
    {
      "name": "local-ollama",
      "provider": "ollama",
      "provider_type": "ollama",
      "base_url": "http://host.docker.internal:11434",
      "model": "qwen2.5-coder",
      "free": true,
      "context_window": 32768,
      "supports_streaming": true
    },
    {
      "name": "cloud-openai",
      "provider": "openai",
      "model": "gpt-4.1-mini",
      "api_key_env": "OPENAI_API_KEY",
      "free": false,
      "context_window": 128000,
      "supports_streaming": true,
      "supports_tools": true,
      "cost_per_million_input": 0.4,
      "cost_per_million_output": 1.6
    }
  ]
}
